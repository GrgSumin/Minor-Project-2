PORT=4000
DB_URL=mongodb://127.0.0.1:27017/instrumentmania
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins.
# Leave empty in dev (permissive). In production, set to the deployed
# storefront + admin URLs, e.g.:
# CORS_ORIGIN=https://instrumentmania.com,https://admin.instrumentmania.com
CORS_ORIGIN=

# Owner notification target (where new orders are emailed)
OWNER_EMAIL=owner@example.com

# SMTP for outbound email — Gmail with an app password works:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Seed an admin account on first run (only used if no admin exists yet)
SEED_ADMIN_EMAIL=admin@instrumentmania.local
SEED_ADMIN_PASSWORD=ChangeMe!123
